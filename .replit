modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Ablation Study"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Run Ablation Study"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u files/ablation_lora.py --data_dir pbl-transformer-main/router_dataset --experiment all --epochs 10 --output_dir agrisense-ai-main/ablation_results"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "start.sh"]
build = ["bash", "-c", "cd agrisense-ai-main/client && npm install && npm run build"]
